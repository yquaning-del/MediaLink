# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://medialink:medialink_dev_password@localhost:5432/medialink_ghana

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_min_64_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_64_chars
BCRYPT_ROUNDS=12
JWT_ACCESS_EXPIRY=30m
JWT_REFRESH_EXPIRY=7d

# ─── Paystack ────────────────────────────────────────────────────
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret

# ─── Flutterwave (fallback) ─────────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxx

# ─── Twilio SMS ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── SendGrid Email ─────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@medialink.com.gh
SENDGRID_FROM_NAME=MediaLink Ghana

# ─── AWS S3 ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=eu-west-1
S3_BUCKET_PROFILES=medialink-ghana-profiles
S3_BUCKET_DOCUMENTS=medialink-ghana-documents

# ─── App ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Production example: https://medialink-ghana.vercel.app
FRONTEND_URL=http://localhost:3000
# Production example: https://your-backend.up.railway.app
API_URL=http://localhost:4000

# ─── CORS ────────────────────────────────────────────────────────
# Additional allowed origins beyond FRONTEND_URL (comma-separated).
# FRONTEND_URL is always included automatically.
# In dev, localhost:3000 and localhost:8081 are added by default.
# Production example: https://medialink-ghana.vercel.app,https://admin.medialink.com.gh
CORS_ORIGINS=

# ─── Admin Security ─────────────────────────────────────────────
ADMIN_ALLOWED_IPS=127.0.0.1,::1

# ─── Pricing (GHS in pesewas: 100 pesewas = 1 GHS; Paystack amount for currency GHS) ─
REGISTRATION_FEE_PESEWAS=5000

# ─── Revenue Share ───────────────────────────────────────────────
DEFAULT_REVENUE_SHARE_RATE=0.05
REVENUE_SHARE_MONTHS=6

# ─── AI Features (OpenAI-compatible API) ─────────────────────────
AI_API_URL=https://api.openai.com/v1
AI_API_KEY=sk-xxxxxxxxxxxx
AI_MODEL=gpt-4o-mini

# ─── GhanaCard API (Phase 2) ────────────────────────────────────
GHANA_CARD_API_URL=
GHANA_CARD_API_KEY=
